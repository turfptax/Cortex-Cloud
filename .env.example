# Cortex Cloud deploy - per-instance settings.
# Copy to `.env` and fill in. `.env` is gitignored; never commit it.
# Every value here is yours alone: your Azure subscription, your Entra
# tenant, your keys. Nothing is shared with any other instance.

# --- Azure placement -------------------------------------------------
# Where the resources live. The resource-group name must be unique in
# your subscription; the location is any Azure region near you.
AZURE_SUBSCRIPTION_ID=""          # az account show --query id -o tsv
RESOURCE_GROUP="cortex-rg"
LOCATION="centralus"

# A short lowercase suffix that makes global names (ACR, storage,
# Key Vault) unique. 4-6 alphanumerics, e.g. "a1b2".
NAME_SUFFIX=""

# --- Identity (who may sign in) --------------------------------------
# The web Hub is locked to ONE person: you. This is your Entra object
# id; only this account can sign in to the site.
#   az ad signed-in-user show --query id -o tsv
OWNER_OID=""

# --- The brain (LLM) -------------------------------------------------
# An OpenRouter API key funds the memory loop (summaries, narratives).
# https://openrouter.ai/keys - get a standalone key for this instance.
OPENROUTER_API_KEY=""

# --- Public URL ------------------------------------------------------
# Leave blank to use the auto-assigned Azure FQDN. Set a custom domain
# (e.g. cortex.example.com) only after you own the DNS; see docs.
CUSTOM_DOMAIN=""

# --- Container image -------------------------------------------------
# The combined image (core + gateway + embed + litestream). Either:
#  (a) build it yourself from source  -> scripts/build-image.sh sets this, or
#  (b) point at a published image     -> e.g. ghcr.io/<owner>/cortex-cloud:latest
# If blank, deploy.sh builds it into your own ACR.
IMAGE=""

# --- Optional: cloud voice -------------------------------------------
# Leave blank to use the browser's built-in voice. A Groq key
# (console.groq.com, free) enables speech-to-text; an ElevenLabs key
# enables higher-quality text-to-speech.
GROQ_API_KEY=""
ELEVENLABS_API_KEY=""
